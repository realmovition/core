# Common build options
build --cxxopt="-std=c++17"
build --jobs=8
build --verbose_failures
build --keep_going

# build --registry=https://bcr.wheelos.cn/
build --registry=https://raw.githubusercontent.com/realmovition/bazel-central-registry/main

# Enable Bzlmod for every Bazel command
common --enable_bzlmod
common:ci --color=yes
common:ci --curses=no
common:ci --show_progress_rate_limit=5
common:lockfile-check --lockfile_mode=error
common:lockfile-update --lockfile_mode=update

# Compilation modes
build:release --compilation_mode=opt --strip=always --copt=-O3
build:debug --compilation_mode=dbg --copt=-g --copt=-O0
build:ci --config=release
test:ci --test_output=errors
